# 원큐 백엔드 베이스 URL (뒤에 /api 붙이지 않는다). 예: http://localhost:8100
ONEQUE_API_BASE=http://localhost:8100

# 이 사이트의 공개 절대 URL. sitemap.xml·robots.txt·JSON-LD 가 절대 URL 을 요구한다(크롤러가
# 상대경로를 정규화하지 못한다). **배포 전 반드시 실제 도메인으로 바꿀 것** — 안 그러면
# 검색엔진에 localhost 가 색인된다. 끝 슬래시는 있어도 되고 없어도 된다.
ONEQUE_SITE_URL=http://localhost:3000
# 이 사이트의 테넌트 코드. 모든 요청에 X-Tenant 로 실린다.
# **반드시 자기 테넌트 코드로 바꿀 것** — 코드에 폴백이 없어서 비우면 기동/빌드가 실패한다(의도).
ONEQUE_TENANT=your-tenant-code

# 스토어프론트 서버 시크릿 키(oqsk_…·memo78/79). 있으면 모든 백엔드 호출에 X-Storefront-Key 로 실려
# 이 사이트를 인증한다. **서버 전용** — NEXT_PUBLIC_ 접두사 절대 금지(브라우저 번들에 시크릿 유출).
# 관리형(원큐 오케스트레이터 서빙)은 기동 시 자동 주입되므로 여기 비워 둔다.
# BYO(자체 배포)는 콘솔에서 발급해 이 값에 넣는다. 부재는 정상(dual 이행기 — 키 없으면 헤더 미전송).
ONEQUE_STOREFRONT_KEY=

# 소셜 로그인 public client_id — 브라우저에 노출되는 값이라 NEXT_PUBLIC_ 접두사를 쓴다.
# client_secret 은 절대 여기 두지 않는다(백엔드 tenant_oauth_app 이 보관·교환). 미설정 provider 버튼은 안내 후 무동작.
NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_NAVER_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# 온디맨드 revalidate 공유 시크릿 (memo31 §0-12·§5.1). 백엔드가 데이터 변경 시
# POST /api/revalidate 를 `x-oneque-revalidate-secret` 헤더로 호출해 ISR 캐시를 무효화한다.
# 미설정이면 그 엔드포인트는 비활성(503). 강한 랜덤값을 넣고 백엔드와 공유한다.
ONEQUE_REVALIDATE_SECRET=

# 프리뷰 모드 플래그 — 프리뷰 러너(memo29 §3)가 `next dev` 프로세스에 =1 로 주입한다.
# =1 이면 프로덕션 공개 API(읽기)만 소비하고 쓰기(체크아웃·장바구니 변경)를 차단해야 한다(프로덕션 데이터 오염 방지).
# 평상시(직접 배포)에는 비워 둔다. lib/preview.ts 의 isPreview() 로 판별한다.
NEXT_PUBLIC_ONEQUE_PREVIEW=
